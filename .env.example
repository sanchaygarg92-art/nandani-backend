# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── PostgreSQL Database ──────────────────────────────────────
# Get this from Railway: railway.app → your project → PostgreSQL → Connect
DATABASE_URL=postgresql://user:password@host:5432/nandani_db

# ─── Firebase Admin SDK ───────────────────────────────────────
# Get from Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then paste the entire JSON on ONE line below
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"nandini-organic",...}

# ─── Admin ────────────────────────────────────────────────────
ADMIN_SECRET=nandani2024

# ─── CORS ─────────────────────────────────────────────────────
# Your app's bundle ID or * for all
ALLOWED_ORIGINS=*
